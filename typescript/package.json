{
  "name": "@council/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for Council AI Governance Platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    },
    "./integrations/vercel-ai": {
      "import": "./dist/integrations/vercel-ai.mjs",
      "require": "./dist/integrations/vercel-ai.js",
      "types": "./dist/integrations/vercel-ai.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/testing.ts src/integrations/vercel-ai.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "council",
    "ai",
    "governance",
    "jury",
    "sdk",
    "agents"
  ],
  "author": "Council Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "eslint": "^8.55.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
